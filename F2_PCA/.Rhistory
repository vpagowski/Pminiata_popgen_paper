cov <- as.matrix(read.table("Pmin_lc_genolike3_R1+R2_maf0.05.covMat"), header = F)
sample_id<-read.csv("Sample_list_251.csv",stringsAsFactors = FALSE)
#Remove samples with very small n and re-sequenced individuals from Bamfield/SB
rows_cols_to_remove <- c(3,10,15,132:133,153,155,156,158)
cov <- cov[-rows_cols_to_remove, -rows_cols_to_remove]
sample_id <- sample_id[-c(3,10,15,132:133,153,155,156,158,), ]
