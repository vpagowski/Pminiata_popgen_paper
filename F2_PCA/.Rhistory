mme.pca <- eigen(cov) #perform the pca using the eigen function.
eigenvectors = mme.pca$vectors #extract eigenvectors
pca.vectors = as_tibble(cbind(pop,id,data.frame(eigenvectors))) #combine with our population assignments
#custom_order<-c("Haida Gwaii","Central BC","Winter Harbor","Ucluelet","Bamfield","Fort Bragg","Monterey","Hazard Canyon","Santa Barbara","LA","San Diego","Ensenada")
custom_order<-c("Winter Harbor","Ucluelet","Bamfield","Fort Bragg","Monterey","Hazard Canyon","Santa Barbara","LA","San Diego","Ensenada")
cols2 <- c("lightsalmon","hotpink2","darkorange","lightgoldenrod2","olivedrab3","mediumseagreen","dodgerblue","lightskyblue1","plum","blueviolet")
#cols2 <- c("deeppink4","burlywood3","lightsalmon","hotpink2","darkorange","lightgoldenrod2","olivedrab3","mediumseagreen","dodgerblue","lightskyblue1","plum","blueviolet")
pca.vectors$pop <- factor(pca.vectors$pop, levels = custom_order)
pca.vectors$Collection <- sample_id$Collection
#Remove pigeon
pca.vectors<-subset(pca.vectors,pca.vectors$pop!="Pigeon")
pca.vectors<-subset(pca.vectors,pca.vectors$pop!="Fbragg_old")
#pca.vectors<-subset(pca.vectors,pca.vectors$pop!="Fbragg")
#pca 7 splits into 2 groups
pca = ggplot(data = pca.vectors, aes(x = X1, y = X2, colour = pop, shape = Collection)) +
geom_point(alpha = 0.6, size=2.5) +
scale_color_manual(values = cols2) +
scale_shape_manual(values = c(17, 15, 16))+ #, guide = guide_legend(override.aes = list(color = "black"))) +
theme(axis.text.x = element_blank(), axis.text.y = element_blank()) +
coord_cartesian(clip = "off") +
labs(color = "Location") +
theme_bw()+
theme(legend.position = "left",
panel.border = element_rect(color = "gray", fill = NA, linewidth = 0.5),legend.text = element_text(size = 12),axis.text = element_text(size = 12))+
labs(x = "PC1 (0.59%)",
y = "")+
scale_y_continuous(position = "right",
sec.axis = dup_axis(
name = "PC2 (0.56%)",
labels = NULL
))
#scale_x_continuous(limits = c(-0, 0.03)) +
#scale_y_continuous(limits = c(-0.1, 0.05))
pca
###NOW assign thresholds to split "males" and "females"
ggplot(pca.vectors, aes(x = pop, y = X2)) +
geom_point(color = "black") +
theme_bw() +
labs(x = "Pop", y = "PC2") +
geom_text(aes(label = id, color="black"), vjust = -0.5, size = 3)+
theme(axis.text.x = element_text(angle = 90, vjust = 0.5, hjust=1))
#REMOVE our Male/Female outliers
pca_vectors_sub <- subset(pca.vectors, !(id %in% c("./bam_bais/ngm_dtas_rg_23442Pal_U7_S103.bam",
"./bam_bais/ngm_dtas_rg_23442Pal_U6_S102.bam",
"./bam_bais/ngm_dtas_rg_23442Pal_S3_S122.bam",
"./bam_bais/ngm_dtas_rg_23442Pal_S12_S131.bam",
"ngm_dtas_rg_24145Pal_Ba10_S56.bam",
"ngm_dtas_rg_24145Pal_Ba13_S58.bam")))
ggplot(pca_vectors_sub, aes(x = pop, y = X2)) +
geom_point(color = "black") +
theme_bw() +
labs(x = "Pop", y = "PC2") +
theme(axis.text.x = element_text(angle = 90, vjust = 0.5, hjust=1))
#Divide into males and females based on PC2
threshold <- 0.001  # Change this value to the desired threshold
project.pca <- pca_vectors_sub %>%
mutate(group_pc2 = ifelse(pca_vectors_sub$X2 > threshold, "Male", "Female"))
MFplt<-ggplot(project.pca, aes(x = X1, y = X2, color = group_pc2)) +
geom_jitter(size=0.6) +
theme_bw() +
scale_color_manual(values = c("Male" = "cadetblue", "Female" = "pink3")) +  # Adjust colors as needed
labs(color = "Group based on PC2", x = "PC1", y = "PC2")
ggplot(scree_data, aes(x = Component, y = VarianceExplained)) +
geom_point() +
geom_line() +
theme_bw()+
scale_x_continuous(limits = c(0, 50)) +
scale_y_continuous(limits = c(0, 0.02))
library(tidyverse)
setwd("/Users/veronicapagowski/Desktop/Patiria_popgen/PCA/")
#Covariance matrix: LD pruned and minIND 10
cov <- as.matrix(read.table("Pmin_lc_genolike3_R1+R2_maf0.05.covMat"), header = F)
sample_id<-read.csv("old_new_bams2.csv",stringsAsFactors = FALSE) #old_new_bams_rmreseq for FbraggO
#rows_cols_to_remove <- c(1:31, 60:69,95:122,149,153,155,156,158,196:198)
#cov <- cov[-rows_cols_to_remove, -rows_cols_to_remove]
#sample_id <- sample_id[-c(1:31, 60:69,95:122,149,153,155,156,158,196:198), ]
pop<-sample_id$group
mme.pca <- eigen(cov) #perform the pca using the eigen function.
eigenvectors = mme.pca$vectors #extract eigenvectors
pca.vectors = as_tibble(cbind(pop, data.frame(eigenvectors))) #combine with our population assignments
#custom_order<-c("Haida Gwaii","Central BC","Winter Harbor","Ucluelet","Bamfield","Fort Bragg","Monterey","Hazard Canyon","Santa Barbara","LA","San Diego","Baja")
custom_order<-c("Winter Harbor","Ucluelet","Bamfield","Fort Bragg","Monterey Male","Monterey Female","Hazard Canyon","Santa Barbara","LA","San Diego","Ensenada")
cols2 <- c("lightsalmon","hotpink2","darkorange","lightgoldenrod2","mediumseagreen","dodgerblue","lightskyblue1","plum","blueviolet","blue1","deeppink")
#cols2 <- c("deeppink4","burlywood3","lightsalmon","hotpink2","darkorange","lightgoldenrod2","olivedrab3","mediumseagreen","dodgerblue","lightskyblue1","plum","blueviolet")
pca.vectors$pop <- factor(pca.vectors$pop, levels = custom_order)
pca.vectors$Collection <- sample_id$Collection
pca.vectors$id <- sample_id$X
#Remove pigeon
pca.vectors<-subset(pca.vectors,pca.vectors$pop!="Pigeon")
pca.vectors<-subset(pca.vectors,pca.vectors$pop!="Fbragg_old")
#pca.vectors<-subset(pca.vectors,pca.vectors$pop!="Fbragg")
#pca 7 splits into 2 groups
pca = ggplot(data = pca.vectors, aes(x = -X1, y = X2, colour = pop, shape = Collection)) +
geom_point(data = subset(pca.vectors, !(pop %in% c("Monterey Male", "Monterey Female"))),
alpha = 0.3, size = 2.5) +
geom_point(data = subset(pca.vectors, pop %in% c("Monterey Male", "Monterey Female")),
alpha = 0.8, size = 2) +
scale_color_manual(values = cols2) +
scale_shape_manual(values = c(17, 15, 16))+ #, guide = guide_legend(override.aes = list(color = "black"))) +
theme(axis.text.x = element_blank(), axis.text.y = element_blank()) +
coord_cartesian(clip = "off") +
labs(color = "Location") +
theme_bw()+
theme(legend.position = "left",
panel.border = element_rect(color = "gray", fill = NA, linewidth = 0.5),legend.text = element_text(size = 12),axis.text = element_text(size = 12))+
labs(x = "PC1 (0.68%)",
y = "")+
scale_y_continuous(position = "right",
sec.axis = dup_axis(
name = "PC2 (0.66%)",
labels = NULL
))
#scale_x_continuous(limits = c(-0, 0.03)) +
#scale_y_continuous(limits = c(-0.1, 0.05))
pca
setwd("/Users/veronicapagowski/Desktop/MOLECOL")
#ggsave(filename = "FIG_PCA_SEXDIFFS.png", plot = pca, width = 6, height = 5, units = "in", dpi = 300)
ggsave(filename = "FIG_PCA_SEXDIFFS.pdf",
plot = pca,
width = 5.5,
height = 4.8,
units = "in")
pca.eigenval.sum = sum(mme.pca$values) #sum of eigenvalues
varPC1 <- (mme.pca$values[1]/pca.eigenval.sum)*100 #Variance explained by PC1
varPC2 <- (mme.pca$values[2]/pca.eigenval.sum)*100 #Variance explained by PC2
varPC3 <- (mme.pca$values[3]/pca.eigenval.sum)*100 #Variance explained by PC3
varPC4 <- (mme.pca$values[4]/pca.eigenval.sum)*100 #Variance explained by PC4
varPC5 <- (mme.pca$values[5]/pca.eigenval.sum)*100 #Variance explained by PC4
varPC6 <- (mme.pca$values[6]/pca.eigenval.sum)*100 #Variance explained by PC4
varPC7 <- (mme.pca$values[7]/pca.eigenval.sum)*100 #Variance explained by PC4
variance_explained <- mme.pca$values/sum(mme.pca$values)
# Create a data frame for the scree plot
scree_data <- data.frame(
Component = 1:length(variance_explained),
VarianceExplained = variance_explained
)
ggplot(scree_data, aes(x = Component, y = VarianceExplained)) +
geom_point() +
geom_line() +
theme_bw()+
scale_x_continuous(limits = c(0, 50)) +
scale_y_continuous(limits = c(0, 0.02))
labs(x = "Component Number", y = "Variance Explained", title = "Scree Plot")
