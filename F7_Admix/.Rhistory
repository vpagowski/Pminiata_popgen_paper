get_colors <- function(n) {
custom_colors <- c("#EEB4B4","#6892CD","plum4","cadetblue","darkseagreen3")
if (n <= 5) {
return(custom_colors[1:n])
} else {
return(colorRampPalette(custom_colors)(n))
}
}
